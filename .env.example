# Copie este arquivo para .env e preencha a chave.
OPENAI_API_KEY=sua_chave_aqui
APP_PASSWORD=DIVINA
APP_DATABASE_FILE=./banco_vetorial/magisteria.sqlite

# Assinatura mensal do Mercado Pago. Use credenciais de teste no desenvolvimento e de producao no servidor.
APP_PUBLIC_URL=https://seu-dominio-publico.example
MERCADO_PAGO_ACCESS_TOKEN=TEST-seu-access-token
MERCADO_PAGO_WEBHOOK_SECRET=sua-assinatura-secreta-de-webhook
MERCADO_PAGO_PRICE=14.99
MERCADO_PAGO_CURRENCY=BRL
FREE_ACCESS_COUPONS=

# Modelo economico adequado para respostas fundamentadas nos trechos recuperados.
OPENAI_MODEL=gpt-5.4-nano

# Geracao rapida das imagens dos slides. Aumente a concorrencia com cautela se sua conta aceitar mais requisicoes simultaneas.
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_CONCURRENCY=3
IMAGE_QUALITY=low

# Em producao no Railway, monte um Volume em /data e defina no painel:
# DOCUMENTS_DIR=/data/Documentos
# VECTOR_DIR=/data/banco_vetorial

# Ajustes opcionais da recuperacao documental.
MAX_CONTEXT_CHUNKS=16
MIN_RELEVANCE_SCORE=0.08
CHUNK_SIZE=1100
CHUNK_OVERLAP=180
