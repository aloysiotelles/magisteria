# Copie este arquivo para .env e preencha a chave.
OPENAI_API_KEY=sua_chave_aqui
APP_PASSWORD=DIVINA

# Modelo econômico adequado para respostas fundamentadas nos trechos recuperados.
OPENAI_MODEL=gpt-5.4-nano

# Geração rápida das imagens dos slides. Aumente a concorrência com cautela se sua conta aceitar mais requisições simultâneas.
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_CONCURRENCY=3
IMAGE_QUALITY=low

# Em producao no Railway, monte um Volume em /data e defina no painel:
# DOCUMENTS_DIR=/data/Documentos
# VECTOR_DIR=/data/banco_vetorial

# Ajustes opcionais da recuperação documental.
MAX_CONTEXT_CHUNKS=16
MIN_RELEVANCE_SCORE=0.08
CHUNK_SIZE=1100
CHUNK_OVERLAP=180
